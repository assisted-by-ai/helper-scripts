#!/bin/bash

## Copyright (C) 2022 - 2025 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## https://www.kicksecure.com/wiki/Unicode#grep-find-unicode-wrapper

set -o errexit
set -o nounset
set -o errtrace
set -o pipefail

check_grep_status() {
  if [ "$1" = "0" ]; then
    true "$0: INFO: Match."
  elif [ "$1" = "1" ]; then
    true "$0: INFO: No match."
  else
    printf '%s\n' "$0: ERROR: grep (syntax?) error! Exiting with code '$1'." >&2
    exit "$1"
  fi
}

command -v sort >/dev/null
command -v mktemp >/dev/null

## end-of-options ("--"):
## There is intentionally not use of end-of-options, because this a wrapper
## around 'grep' and the user is supposed to inject their own command line
## options such as for example '--recursive'. It remains the responsibility of
## the user to use end-of-options.

## Safeguard against user-supplied options that would defeat the wrapper:
## grep's '-I' (alias '--binary-files=without-match') and '--binary-files=binary'
## make grep skip any file it classifies as binary (e.g. any file containing a
## NUL byte). Because user options are appended after the wrapper's own
## '--binary-files=text' and grep honors the last occurrence, a caller passing
## '-I' (or a clustered form such as '-rI') would silently hide hostile bytes
## embedded in files with NULs. Refuse these options at the wrapper boundary.
## Scanning stops at '--' so filenames following end-of-options are not
## inspected. Clustered short-option detection is intentionally coarse (any
## '-...I...' is rejected); this wrapper has no use for grep short options
## that take in-cluster values such as '-eFOO', so false positives are
## unlikely in practice.
for arg in "$@"; do
  case "$arg" in
    --)
      break
      ;;
    --binary-files=without-match|--binary-files=binary)
      printf '%s\n' "$0: ERROR: refusing option '$arg': would defeat unicode detection." >&2
      exit 2
      ;;
    -I)
      printf '%s\n' "$0: ERROR: refusing option '-I': would defeat unicode detection." >&2
      exit 2
      ;;
    --*)
      ## other long options are fine
      :
      ;;
    -*I*)
      printf '%s\n' "$0: ERROR: refusing option '$arg' (contains '-I'): would defeat unicode detection." >&2
      exit 2
      ;;
  esac
done

## --binary-files=text - required to find backspace and null character
## --null - write a NUL byte (not a newline) after each matching filename.
## Required to survive filenames that contain embedded newlines: with the
## default newline separator, a path like $'evil\nfile.txt' is split across
## two output lines and a downstream 'sort --unique' would treat the halves
## as independent records, mangling the filename list. NUL-delimited output
## combined with 'sort --zero-terminated' keeps one record per filename
## regardless of what bytes the filename contains.
grep_args=(
  --files-with-matches
  --line-number
  --binary-files=text
  --null
)

## Collect each pass's NUL-delimited filename list into a temporary file.
## Previous versions captured output with command substitution ("$(...)"),
## which (a) strips embedded NUL bytes unconditionally -- so the '--null'
## separators above would be silently eaten and all filenames would be
## concatenated into a single record -- and (b) cannot hold NUL-delimited
## data in a bash string in the first place. Writing to files avoids both
## problems and keeps error codes per pass so 'check_grep_status' still
## distinguishes "no match" (1) from "grep error" (>=2).
tmp_dir="$(mktemp --directory)"
# shellcheck disable=SC2064
trap "rm -rf -- ${tmp_dir@Q}" EXIT

set +o errexit

LC_ALL=C grep "${grep_args[@]}" --perl-regexp '[^\x00-\x7F]' "$@" \
  > "$tmp_dir/1"
check_grep_status "$?"

LC_ALL=C grep "${grep_args[@]}" --perl-regexp "[^[:ascii:]]" "$@" \
  > "$tmp_dir/2"
check_grep_status "$?"

## https://access.redhat.com/security/vulnerabilities/RHSB-2021-007
## https://lintian.debian.org/tags/unicode-trojan
##
## '--perl-regexp':
## Not using 'grep's '--perl-regexp' option for three.
## Because not mentioned in above links and can lead to the following error message:
# grep: PCRE2 does not support \F, \L, \l, \N{name}, \U, or \u
#three="$(LC_ALL=C grep "${grep_args[@]}" $'[\u061C\u200E\u200F\u202A\u202B\u202C\u202D\u202E\u2066\u2067\u2068\u2069]' "$@")"
## Using different syntax to avoid encoding issue.
##
## testfile content:
## 15.0.4
##
## hexdump:
## 0000000 3531 302e 342e 000a
## 0000007
##
## sha512sum testfile
## 0196f0043f8a77fb1d757acae601b460026b02857341c3ec407fbf0a88471882eae5beaa517afebabc63fabe21c84d10a2a67f9655ea2026d9b9b8f61969f585
LC_ALL=C grep "${grep_args[@]}" --fixed-strings \
  -e $'\xD8\x9C' \
  -e $'\xE2\x80\x8E' \
  -e $'\xE2\x80\x8F' \
  -e $'\xE2\x80\xAA' \
  -e $'\xE2\x80\xAB' \
  -e $'\xE2\x80\xAC' \
  -e $'\xE2\x80\xAD' \
  -e $'\xE2\x80\xAE' \
  -e $'\xE2\x81\xA6' \
  -e $'\xE2\x81\xA7' \
  -e $'\xE2\x81\xA8' \
  -e $'\xE2\x81\xA9' \
  "$@" \
  > "$tmp_dir/3"
check_grep_status "$?"

## ASCII control characters.
LC_ALL=C grep "${grep_args[@]}" \
  --perl-regexp '[\x00-\x08\x0B\x0C\x0D\x0E-\x1F\x7F]' "$@" \
  > "$tmp_dir/4"
check_grep_status "$?"

set -o errexit

## Merge, sort and de-duplicate in the NUL domain, then read the result
## back into a bash array with 'read -d ""'. Each array element is exactly
## one filename; no byte value (newline, tab, NUL-stripped-by-$(...), etc.)
## can corrupt record boundaries any more.
declare -a matches=()
while IFS= read -r -d '' match_file; do
  matches+=("$match_file")
done < <(
  LC_ALL=C sort --zero-terminated --unique \
    "$tmp_dir/1" "$tmp_dir/2" "$tmp_dir/3" "$tmp_dir/4"
)

if [ "${#matches[@]}" -eq 0 ]; then
  ## No matches found, therefore 'exit 1'.
  ## This is consistent with 'grep', which also exits non-zero if no match has been found.
  exit 1
fi

## Print one filename per line, shell-quoted. 'printf %q' is used instead
## of plain echo/stecho so that filenames containing newlines, tabs, or
## other control bytes remain on a single output line (emitted as a $'...'
## literal), preserving the "one line = one file" contract that downstream
## shell pipelines rely on. Ordinary filenames with no special characters
## are printed verbatim, so existing callers see no visible change.
for match_file in "${matches[@]}"; do
  printf '%q\n' "$match_file"
done

## Matches found, therefore 'exit 0'.
## This is consistent with 'grep', which also exits 0 if matches have been found.
