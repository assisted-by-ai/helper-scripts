#!/bin/bash

## Copyright (C) 2022 - 2025 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## https://www.kicksecure.com/wiki/Unicode#grep-find-unicode-wrapper

set -o errexit
set -o nounset
set -o errtrace
set -o pipefail

check_grep_status() {
  if [ "$1" = "0" ]; then
    true "$0: INFO: Match."
  elif [ "$1" = "1" ]; then
    true "$0: INFO: No match."
  else
    printf '%s\n' "$0: ERROR: grep (syntax?) error! Exiting with code '$1'." >&2
    exit "$1"
  fi
}

command -v sort >/dev/null

## end-of-options ("--"):
## There is intentionally not use of end-of-options, because this a wrapper
## around 'grep' and the user is supposed to inject their own command line
## options such as for example '--recursive'. It remains the responsibility of
## the user to use end-of-options.

## Whitelist user-supplied grep options. Because the wrapper runs grep with
## hard-coded semantics ('--files-with-matches --binary-files=text --null'
## plus its own patterns), nearly any additional grep flag can break one of
## those guarantees:
##
##   -q / --quiet               grep suppresses output but still exits 0 on
##                              match, so the wrapper collects no filenames
##                              and wrongly reports "no match" (exit 1).
##   -L / --files-without-match flips '-l' and makes grep print CLEAN files
##                              as matches -- massive false positives.
##   -v / --invert-match        inverts the hard-coded patterns, so every
##                              non-hostile file is reported.
##   -m NUM (especially -m 0)   limits matches per file and, for small NUM,
##                              can suppress legitimate matches.
##   -c / --count               changes output format away from "filename
##                              per record".
##   -e PAT / -f FILE           add extra patterns, which either inject
##                              false positives or shove the wrapper's own
##                              positional pattern into the filename slot,
##                              causing a grep argument-parse error.
##   -I / --binary-files=...    overrides '--binary-files=text' so files
##                              classified as binary (NUL-containing) are
##                              silently skipped, hiding control bytes.
##   -h / -H / --label= / -Z / --null-data / ...
##                              change filename handling in ways that
##                              invalidate the NUL-delimited parsing the
##                              wrapper relies on.
##
## The safe set is therefore small. Allow only:
##   * bare positional arguments (files and paths),
##   * '--' end-of-options (and anything after it is positional),
##   * recursion controls: -r, -R, --recursive, --dereference-recursive,
##   * path filters: --include[=], --exclude[=], --exclude-dir[=],
##                   --exclude-from[=],
##   * -s / --no-messages (suppress "Permission denied" spam).
##
## Anything else is refused with a clear error. This is a whitelist on
## purpose: blacklisting individual dangerous flags is unmaintainable
## because grep's option surface is large and new dangerous flags can
## appear in future grep versions.
expect_value_for=""
for arg in "$@"; do
  if [ -n "$expect_value_for" ]; then
    ## Previous iteration saw a space-separated long option that takes
    ## a value (e.g. '--include PATTERN'); accept this arg as its value
    ## regardless of what it looks like.
    expect_value_for=""
    continue
  fi
  case "$arg" in
    --)
      ## End-of-options: every remaining argument is positional. Stop
      ## validating.
      break
      ;;
    -r|-R|--recursive|--dereference-recursive|-s|--no-messages)
      ## Bare allowed flags.
      ;;
    -[rRs][rRs]|-[rRs][rRs][rRs])
      ## Clustered combinations of the allowed short flags only
      ## (e.g. '-rs', '-Rs', '-rRs'). Any cluster containing a letter
      ## outside {r, R, s} falls through to the '-*' reject branch.
      ;;
    --include=*|--exclude=*|--exclude-dir=*|--exclude-from=*)
      ## Long option with attached value.
      ;;
    --include|--exclude|--exclude-dir|--exclude-from)
      ## Long option with space-separated value: consume next arg.
      expect_value_for="$arg"
      ;;
    -*)
      printf '%s\n' \
        "$0: ERROR: refusing grep option '$arg': not on the wrapper's allowlist." \
        "$0: Allowed: -r -R --recursive --dereference-recursive -s --no-messages" \
        "$0: Allowed: --include[=] --exclude[=] --exclude-dir[=] --exclude-from[=] --" \
        "$0: See the comment block above this check for the rationale." >&2
      exit 2
      ;;
    *)
      ## Bare positional (a file or directory path). Allowed.
      ;;
  esac
done
if [ -n "$expect_value_for" ]; then
  printf '%s\n' \
    "$0: ERROR: option '$expect_value_for' is missing its value." >&2
  exit 2
fi

## --binary-files=text - required to find backspace and null character
## --null - write a NUL byte (not a newline) after each matching filename.
## Required to survive filenames that contain embedded newlines: with the
## default newline separator, a path like $'evil\nfile.txt' is split across
## two output lines and a downstream 'sort --unique' would treat the halves
## as independent records, mangling the filename list. NUL-delimited output
## combined with 'sort --zero-terminated' keeps one record per filename
## regardless of what bytes the filename contains.
grep_args=(
  --files-with-matches
  --line-number
  --binary-files=text
  --null
)

## Collect each pass's filenames directly into a bash array, without
## command substitution and without temporary files.
##
## Previous versions captured output with "$(grep ...)". Two problems:
##   (a) bash command substitution unconditionally strips embedded NUL
##       bytes, so '--null' separators are eaten and all filenames
##       concatenate into a single record;
##   (b) newline-separated output corrupts filenames that contain '\n'.
##
## The fix is a plain pipeline
##
##     grep ... | collect_matches
##
## where 'collect_matches' is a bash function that does
##   'while IFS= read -r -d "" f; do matches+=("$f"); done'.
##
## Normally the right-hand side of a pipe runs in a subshell and any
## array mutation would be lost. 'shopt -s lastpipe' (combined with job
## control turned off via 'set +m', which is the default in scripts
## anyway but is set explicitly for safety) makes the *last* command of
## a pipeline run in the current shell, so 'matches+=(...)' persists.
## '${PIPESTATUS[0]}' still gives us grep's exit code, so
## 'check_grep_status' continues to distinguish "no match" (1) from
## "grep error" (>=2).
set +m
shopt -s lastpipe

declare -a matches=()
collect_matches() {
  local match_file
  while IFS= read -r -d '' match_file; do
    matches+=("$match_file")
  done
}

set +o errexit

LC_ALL=C grep "${grep_args[@]}" --perl-regexp '[^\x00-\x7F]' "$@" \
  | collect_matches
check_grep_status "${PIPESTATUS[0]}"

LC_ALL=C grep "${grep_args[@]}" --perl-regexp "[^[:ascii:]]" "$@" \
  | collect_matches
check_grep_status "${PIPESTATUS[0]}"

## https://access.redhat.com/security/vulnerabilities/RHSB-2021-007
## https://lintian.debian.org/tags/unicode-trojan
##
## '--perl-regexp':
## Not using 'grep's '--perl-regexp' option for three.
## Because not mentioned in above links and can lead to the following error message:
# grep: PCRE2 does not support \F, \L, \l, \N{name}, \U, or \u
#three="$(LC_ALL=C grep "${grep_args[@]}" $'[\u061C\u200E\u200F\u202A\u202B\u202C\u202D\u202E\u2066\u2067\u2068\u2069]' "$@")"
## Using different syntax to avoid encoding issue.
##
## testfile content:
## 15.0.4
##
## hexdump:
## 0000000 3531 302e 342e 000a
## 0000007
##
## sha512sum testfile
## 0196f0043f8a77fb1d757acae601b460026b02857341c3ec407fbf0a88471882eae5beaa517afebabc63fabe21c84d10a2a67f9655ea2026d9b9b8f61969f585
LC_ALL=C grep "${grep_args[@]}" --fixed-strings \
  -e $'\xD8\x9C' \
  -e $'\xE2\x80\x8E' \
  -e $'\xE2\x80\x8F' \
  -e $'\xE2\x80\xAA' \
  -e $'\xE2\x80\xAB' \
  -e $'\xE2\x80\xAC' \
  -e $'\xE2\x80\xAD' \
  -e $'\xE2\x80\xAE' \
  -e $'\xE2\x81\xA6' \
  -e $'\xE2\x81\xA7' \
  -e $'\xE2\x81\xA8' \
  -e $'\xE2\x81\xA9' \
  "$@" \
  | collect_matches
check_grep_status "${PIPESTATUS[0]}"

## ASCII control characters.
LC_ALL=C grep "${grep_args[@]}" \
  --perl-regexp '[\x00-\x08\x0B\x0C\x0D\x0E-\x1F\x7F]' "$@" \
  | collect_matches
check_grep_status "${PIPESTATUS[0]}"

set -o errexit

if [ "${#matches[@]}" -eq 0 ]; then
  ## No matches found, therefore 'exit 1'.
  ## This is consistent with 'grep', which also exits non-zero if no match has been found.
  exit 1
fi

## De-duplicate and sort the accumulated filenames without temp files.
## Each filename is re-emitted NUL-terminated via 'printf %s\0' so that
## embedded newlines/tabs/etc. survive the sort, then the final print
## loop formats each record. Filenames that contain an ASCII control
## byte (newline, tab, ESC, DEL, ...) would corrupt the "one line =
## one file" contract or inject terminal escapes, so those are printed
## with 'printf %q\n' as a $'...' literal. Filenames without control
## bytes -- including ordinary UTF-8 names like 'café.txt' -- are
## printed verbatim with 'printf %s\n', matching the previous output
## format for the common case. LC_ALL=C makes the [[:cntrl:]] class
## byte-based so the decision is not locale-sensitive.
export LC_ALL=C
printf '%s\0' "${matches[@]}" \
  | sort --zero-terminated --unique \
  | while IFS= read -r -d '' match_file; do
      case $match_file in
        *[[:cntrl:]]*)
          printf '%q\n' "$match_file"
          ;;
        *)
          printf '%s\n' "$match_file"
          ;;
      esac
    done

## Matches found, therefore 'exit 0'.
## This is consistent with 'grep', which also exits 0 if matches have been found.
