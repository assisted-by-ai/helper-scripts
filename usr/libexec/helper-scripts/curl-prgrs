#set -x
set -e
set -o nounset
set -o pipefail
set -o errtrace

## provides: draw_progress_bar
source /usr/libexec/helper-scripts/progress-bar

## provides: is_whole_number
source /usr/libexec/helper-scripts/strings.bsh

## provides: has
source /usr/libexec/helper-scripts/has.sh

initialize_terminal() {
  # We want to print the progress bar to stderr, but only if stderr is a
  # terminal. To avoid a conditional every time we print something, we can
  # instead print everything to file descriptor 4, and then point that file
  # descriptor to the right place: stderr if it's a TTY, or /dev/null
  # otherwise.
  if [ -t 2 ]; then
    exec 4>&2
  else
    exec 4>/dev/null
  fi
}

initialize_variables() {
  : "${CURL:="curl"}"
  : "${CURL_PRGRS_MAX_FILE_SIZE_BYTES:=""}"
  : "${CURL_OUT_FILE:=""}"
  : "${CURL_PRGRS_EXEC:=""}"
  : "${curl_prgrs_print_progress:="yes"}"
  percent_last=""
  ## "yes" means the server-reported Content-Length is known and matches
  ## what will be written to disk. Set to "no" when Content-Length is
  ## missing or when transparent decompression makes the on-disk size
  ## differ from the reported value. When "no", the progress bar and
  ## the 114/115 size-equality checks are both skipped; the 81
  ## max-filesize cap still applies.
  curl_prgrs_length_known="yes"

  has "$CURL"
  has safe-rm
  has mktemp
  has stecho
  has stcat

  temporary_directory="$(mktemp --directory)"

  # Compute names for our temporary files by joining the current date and
  # time with the current process ID. We will need two temporary files: one
  # for reading progress information from curl, and another for sending the
  # exit status of curl from the forked child process back to the parent.
  statusfile="${temporary_directory}/status"

  ## curl's PID is set in the backgrounded curl_download subshell and
  ## does not propagate back to the parent. The subshell writes it here
  ## so that the parent's shutdown handler can kill curl directly on
  ## SIGTERM/SIGINT/SIGHUP rather than orphaning it.
  curl_pidfile="${temporary_directory}/curl.pid"

  expected_header_size=8000
  maximum_http_header_size=32000
}

check_variables() {
  if [ "$CURL_OUT_FILE" = "" ]; then
    stecho "${BASH_SOURCE[0]} ERROR: Variable CURL_OUT_FILE is empty." >&4
    exit 57
  fi
  if [ "$CURL_PRGRS_MAX_FILE_SIZE_BYTES" = "" ]; then
    stecho "${BASH_SOURCE[0]} ERROR: Variable CURL_PRGRS_MAX_FILE_SIZE_BYTES is empty." >&4
    exit 57
  fi

  is_whole_number "$CURL_PRGRS_MAX_FILE_SIZE_BYTES"
  is_whole_number "$expected_header_size"
  is_whole_number "$maximum_http_header_size"
}

# Define our `shutdown` function, which will be responsible for cleaning
# up when the program terminates, either normally or abnormally.
shutdown() {
  local exit_code="$?"
  local signal="$1"
  if [ "$signal" = "err" ]; then
    stecho "${BASH_SOURCE[0]} ERROR: Signal $signal received. Exiting." >&4
    stecho "${BASH_SOURCE[0]} ERROR: BASH_COMMAND '$BASH_COMMAND' exit code '$exit_code'." >&4
  elif [ "$signal" = "exit" ]; then
    true "${BASH_SOURCE[0]} INFO: Signal $signal received. Exiting."
  else
    stecho "${BASH_SOURCE[0]} INFO: Signal $signal received. Exiting." >&4
  fi

  trap - SIGHUP SIGINT SIGTERM ERR EXIT

  # If we wrote an exit status to the temporary file, read it. Otherwise,
  # we reached this trap function abnormally; assume a non-zero status.

  sync

  local status

  if [ -n "${statusfile-}" ] && [ -f "$statusfile" ]; then
    true "${BASH_SOURCE[0]} INFO: got status file"
    status="$(stcat "$statusfile")"
    if ! is_whole_number "$status"; then
      true "${BASH_SOURCE[0]} ERROR: status is not a number! status: '$status'"
      status="111"
      error_exit_code="111"
    fi
  else
    true "${BASH_SOURCE[0]} ERROR: no status file"
    status="112"
    error_exit_code="112"
  fi

  ## Prefer the specific status that curl_exit wrote to the statusfile
  ## (e.g. 81, 114, 115, any genuine curl code). Only derive an exit
  ## code from the signal itself when nothing specific was recorded —
  ## otherwise a SIGTERM arriving mid-download would inherit the stale
  ## 0 written by the preceding HEAD probe.
  if [ -z "${error_exit_code-}" ] && [ "$status" = "0" ]; then
    case "$signal" in
      err)     error_exit_code=110 ;;
      sigint)  error_exit_code=130 ;;
      sigterm) error_exit_code=143 ;;
      sighup)  error_exit_code=129 ;;
    esac
  fi

  # If we are exiting normally, jump back to the beginning of the line
  # and clear it. Otherwise, print a newline.
  if [ "$status" -eq 0 ]; then
    printf '%b' "\x1B[0G\x1B[0K" >&4
  else
    printf '%s\n' '' >&4
  fi

  #stat="$(stcat "$statusfile")"
  #stecho "$stat" >&4

  ## Recover curl's PID from the shared pidfile: when shutdown runs in
  ## the parent shell, the local curl_pid is unset (it was assigned
  ## inside the backgrounded curl_download subshell). Without this,
  ## SIGTERM to the script would orphan the running curl process.
  local curl_pid_from_file=""
  if [ -n "${curl_pidfile-}" ] && [ -f "$curl_pidfile" ]; then
    curl_pid_from_file="$(stcat "$curl_pidfile")"
    if ! is_whole_number "$curl_pid_from_file"; then
      curl_pid_from_file=""
    fi
  fi

  : "${curl_pid:=""}"
  : "${curl_download_pid:=""}"

  processes_list="$curl_pid $curl_pid_from_file $curl_download_pid"
  for processes_item in $processes_list ; do
    if kill -0 -- "$processes_item" 2>/dev/null ; then
      #ps -p "$processes_item" || true
      kill -s sigkill -- "$processes_item" &>/dev/null || true
    fi
  done

  ## Only the original shell should clean up the temp dir. If shutdown
  ## runs inside a backgrounded subshell (BASHPID != $$), removing the
  ## statusfile here would leave the parent with no way to recover the
  ## specific exit code written by curl_exit. Cleanup runs after the
  ## kill step so we can read curl_pidfile first.
  if [ "$BASHPID" = "$$" ]; then
    if [ -n "${temporary_directory-}" ]; then
      safe-rm -r -f -- "$temporary_directory"
    fi
  fi

  if [ -n "${error_exit_code-}" ]; then
     true "${BASH_SOURCE[0]} INFO: exit with error_exit_code $error_exit_code"
     exit "$error_exit_code"
  fi

  true "${BASH_SOURCE[0]} INFO: exit with status $status"
  exit "$status"
}

traps_enable() {
  # Register our `shutdown` function to be invoked when the process dies.
  trap "shutdown sigint" SIGINT
  trap "shutdown sigterm" SIGTERM
  trap "shutdown err" ERR
  trap "shutdown exit" EXIT
  trap "shutdown sighup" SIGHUP
}

# The `print_progress` function draws our progress bar to the screen. It
# takes two arguments: the number of bytes read so far, and the total
# number of bytes expected.
print_progress() {
  local bytes="$1"
  local length="$2"

  if ! is_whole_number "$bytes" ; then
    curl_exit 113
  fi
  if ! is_whole_number "$length" ; then
    curl_exit 113
  fi

  # If we are expecting less than 8 KB of data, don't bother drawing a
  # progress bar. (This helps avoid a flicker when following redirects.)
  #[ "$length" -gt 8192 ] || return 0

  # Avoid division by zero when the server reports Content-Length: 0.
  if [ "$length" -le 0 ]; then
    return 0
  fi

  # Calculate the progress percentage and the size of the filled and
  # unfilled portions of the progress bar.
  local percent
  true "${BASH_SOURCE[0]} INFO: bytes: '$bytes'"
  true "${BASH_SOURCE[0]} INFO: length: '$length'"
  percent=$(( bytes * 100 / length ))

  if ! is_whole_number "$percent" ; then
    curl_exit 113
  fi

  if [ "$percent" -ge "100" ]; then
    percent=100
  fi

  if [ "$percent_last" = "$percent" ]; then
    true "${BASH_SOURCE[0]} INFO: percentage number unchanged. Not re-drawing progress bar to avoid flicker."
  else
    draw_progress_bar "$percent" >&4
    if [ "$CURL_PRGRS_EXEC" = "" ]; then
      true "${BASH_SOURCE[0]} INFO: CURL_PRGRS_EXEC is empty. Not executing CURL_PRGRS_EXEC."
    else
      true "${BASH_SOURCE[0]} INFO: CURL_PRGRS_EXEC is set. Executing CURL_PRGRS_EXEC..."
      true "${BASH_SOURCE[0]} INFO: $CURL_PRGRS_EXEC '$percent'"
      $CURL_PRGRS_EXEC "$percent" >&4
      true "${BASH_SOURCE[0]} INFO: CURL_PRGRS_EXEC success."
    fi
  fi

  percent_last="$percent"
}

## Tolerate a missing or non-numeric Content-Length (chunked transfer,
## dynamic responses, some CDNs). Disables the progress bar and the
## strict 114/115 size-equality checks since there is nothing to
## compare against; the 81 max-filesize cap from
## CURL_PRGRS_MAX_FILE_SIZE_BYTES still bounds the download.
handle_unknown_content_length() {
  curl_prgrs_length_known="no"
}

curl_exit() {
  curl_exit_code="$1"
  true "${BASH_SOURCE[0]} INFO: write $curl_exit_code to $statusfile"
  stecho "$curl_exit_code" > "$statusfile"
  if [ "$curl_exit_code" = "0" ]; then
    return 0
  fi
  : "${curl_pid:=""}"
  if [ "$curl_pid" != "" ]; then
    if kill -0 -- "$curl_pid" 2>/dev/null; then
      kill -s SIGKILL -- "$curl_pid" &>/dev/null || true
    fi
  fi
  return "$curl_exit_code"
}

## Stat the output file and enforce the max-filesize cap. Used both
## inside the polling loop and once more after curl exits, so a fast
## completion that slips between poll iterations cannot evade the TUF
## endless-data mitigation.
enforce_max_filesize() {
  if [ ! -f "$CURL_OUT_FILE" ]; then
    return 0
  fi
  size_file_downloaded_bytes="$(stat -c "%s" "$CURL_OUT_FILE")"
  if ! is_whole_number "$size_file_downloaded_bytes" ; then
    curl_exit 113
  fi
  if [ "$size_file_downloaded_bytes" -gt "$CURL_PRGRS_MAX_FILE_SIZE_BYTES" ]; then
    curl_exit 81
  fi
}

curl_download() {
  local size_file_downloaded_bytes

  $CURL --no-progress-meter "$@" &
  curl_pid="$!"
  stecho "$curl_pid" > "$curl_pidfile"

  if ! is_whole_number "$curl_prgrs_content_length" ; then
    handle_unknown_content_length
  fi

  while true ; do
    if [ -f "$CURL_OUT_FILE" ]; then
      enforce_max_filesize

      if [ "$curl_prgrs_length_known" = "yes" ]; then
        true "size_file_downloaded_bytes: $size_file_downloaded_bytes"
        true "curl_prgrs_content_length: $curl_prgrs_content_length"
        if [ "$size_file_downloaded_bytes" -gt "$curl_prgrs_content_length" ]; then
          curl_exit 114
        fi

        if [ "$curl_prgrs_print_progress" = "yes" ]; then
          ## Need to print to stderr to avoid confusing the stdout output of this command.
          #stecho "${BASH_SOURCE[0]} INFO: print_progress '$size_file_downloaded_bytes' '$curl_prgrs_content_length'" >&2
          print_progress "$size_file_downloaded_bytes" "$curl_prgrs_content_length"
        fi
      fi
    fi

    if ! kill -0 -- "$curl_pid" 2>/dev/null; then
      break
    fi

    sleep 1
  done

  ## curl already terminated. Recheck the max-filesize cap on the final
  ## file: the loop body may have run zero times or may have missed
  ## bytes written in the final burst before curl exited.
  enforce_max_filesize

  : "${size_file_downloaded_bytes:=""}"
  if [ "$curl_prgrs_length_known" = "yes" ] \
     && is_whole_number "$size_file_downloaded_bytes" ; then
    true "size_file_downloaded_bytes: $size_file_downloaded_bytes"
    true "curl_prgrs_content_length: $curl_prgrs_content_length"
    if [ "$header_download" = "false" ]; then
      if [ "$size_file_downloaded_bytes" -lt "$curl_prgrs_content_length" ]; then
        curl_exit 115
      fi
    fi
  fi

  curl_exit_code=0
  wait "$curl_pid" || { curl_exit_code=$? ; true; };
  curl_exit "$curl_exit_code"
}

## Single pass over the user-supplied curl args:
## - builds header_arguments: a copy with body-writing and resume-related
##   flags stripped, safe to pass to a HEAD probe.
## - sets curl_prgrs_length_known="no" if the user requested transparent
##   decompression, since the on-disk size will then legitimately differ
##   from the server-reported Content-Length and would otherwise produce
##   spurious 114/115 mismatches and a misleading progress bar.
scan_curl_arguments() {
  local arg_item
  local arg_list=()
  local skip_next=false
  header_arguments=()

  for arg_item in "$@"; do
    case "$arg_item" in
      --compressed|--tr-encoding|--compressed-ssh)
        curl_prgrs_length_known="no"
        ;;
    esac

    if [ "$skip_next" = true ]; then
      skip_next=false
      continue
    fi

    case "$arg_item" in
      ## Options that take a value as the next argument.
      --continue-at|-C|--output|-o)
        skip_next=true
        continue
        ;;
      --continue-at=*|--output=*)
        continue
        ;;
      ## -O/--remote-name and -J/--remote-header-name would otherwise
      ## cause curl to write the response body to a filename derived
      ## from the URL or Content-Disposition header during the HEAD
      ## probe.
      -O|--remote-name|-J|--remote-header-name|--remote-name-all)
        continue
        ;;
      ## Body-writing / method-changing flags. A HEAD probe must not
      ## send a request body, and -X/--request would override the
      ## --head we add. Strip the flag and its value.
      -d|--data|--data-ascii|--data-binary|--data-urlencode|--data-raw|-F|--form|--form-string|-T|--upload-file|-X|--request)
        skip_next=true
        continue
        ;;
      --data=*|--data-ascii=*|--data-binary=*|--data-urlencode=*|--data-raw=*|--form=*|--form-string=*|--upload-file=*|--request=*)
        continue
        ;;
      ## -G/--get has no value but changes data-handling semantics and
      ## is meaningless without -d; safe to drop for a HEAD probe.
      -G|--get)
        continue
        ;;
    esac

    arg_list+=("$arg_item")
  done

  header_arguments=("${arg_list[@]}")

  ## Cannot use. Collapses newlines.
  #stecho "${args[@]}"
}

main() {
  local header_file

  ## {{{ Debugging.
#   local i arg
#   printf '%s\n' "Before number of args: $#"
#   i=0
#   for arg in "$@"; do
#     i=$(( i + 1 ))
#     printf '  [%d]=%q\n' "$i" "$arg"
#   done
  ## }}}

  ## sets: header_arguments, curl_prgrs_length_known
  scan_curl_arguments "$@"

  ## {{{ Debugging.
#   printf '%s\n' ""
#   printf '%s\n' "After number of args: ${#header_arguments[@]}"
#   i=0
#   for arg in "${header_arguments[@]}"; do
#     i=$(( i + 1 ))
#     printf '  [%d]=%q\n' "$i" "$arg"
#   done
  ## }}}

  header_file="$temporary_directory/header"

  true "${BASH_SOURCE[0]} INFO: Download header..."

  ## Determine curl_prgrs_content_length.
  ## While we don't know the expected size of the header,
  ## curl_prgrs_content_length and
  ## CURL_PRGRS_MAX_FILE_SIZE_BYTES are set to reasonable values.
  ##
  ## CURL_PRGRS_EXEC="" to avoid a progress bar for the header download.
  ## That would confuse yad.
  ##
  ## CURL_OUT_FILE and
  ## --output "$header_file" to avoid overwriting files when using "--continue-at -".
  ## '--write-out' will echo.
  ## curl_prgrs_length_known="no" for the HEAD probe: the
  ## "expected_header_size" sentinel of 8000 is just a placeholder, not
  ## an actual prediction of header bytes, so the 114/115 size-equality
  ## checks must not be applied and the progress bar must not be drawn.
  ## The 81 cap via maximum_http_header_size still enforces an upper
  ## bound.
  curl_prgrs_content_length="$(
    header_download="true" \
    curl_prgrs_content_length="$expected_header_size" \
    curl_prgrs_length_known="no" \
    CURL_PRGRS_MAX_FILE_SIZE_BYTES="$maximum_http_header_size" \
    CURL_PRGRS_EXEC="" \
    CURL_OUT_FILE="$header_file" \
      curl_download \
        --head \
        --write-out '%header{Content-Length}' \
        "${header_arguments[@]}" \
        --output "$header_file" \
    )"

  ## Reset from previews invocation of curl_download, which calls print_progress.
  percent_last=""

  true "${BASH_SOURCE[0]} INFO: Header download done."

  if ! is_whole_number "$curl_prgrs_content_length" ; then
    handle_unknown_content_length
  fi

  true "${BASH_SOURCE[0]} INFO: Download file..."

  ## Launching into the background required.
  ## If attempting to refactor this, make sure signal sigterm stops downloads.
  header_download="false" curl_download "$@" &
  curl_download_pid="$!"

  wait_exit_code=0
  wait "$curl_download_pid" &>/dev/null || { wait_exit_code=$? ; true; };
  true "${BASH_SOURCE[0]} INFO: File download done."
  true "${BASH_SOURCE[0]} INFO: END."
  exit "$wait_exit_code"
}

## FD 4 must be opened before traps are installed: the shutdown handler
## writes diagnostics to >&4, and an early failure before
## initialize_terminal would otherwise hit "Bad file descriptor".
initialize_terminal
traps_enable
initialize_variables
check_variables
main "$@"

